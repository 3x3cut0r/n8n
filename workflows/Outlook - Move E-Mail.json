    {
      "parameters": {
        "jsCode": "const raw = $json || {};\nconst messageId = typeof raw.messageId === 'string' ? raw.messageId.trim() : '';\nconst folderId = typeof raw.folderId === 'string' ? raw.folderId.trim() : '';\n\nlet error = '';\nif (!messageId) {\n  error = 'Input field messageId is required and must be a non-empty string.';\n} else if (!folderId) {\n  error = 'Input field folderId is required and must be a non-empty string.';\n}\n\nreturn [{\n  json: {\n    messageId,\n    folderId,\n    okToMove: !error,\n    error\n  }\n}];"
      },
