    {
      "parameters": {
        "jsCode": "const response = $json || {};\nconst statusCode = Number(response.statusCode || 0) || null;\nconst hasError = !!response.error || !!response.message;\nconst ok = !hasError && (statusCode === null || (statusCode >= 200 && statusCode < 300));\n\nreturn [{\n  json: {\n    ok,\n    action: 'move',\n    messageId: $('Normalize and validate input').item.json.messageId || null,\n    folderId: $('Normalize and validate input').item.json.folderId || null,\n    statusCode,\n    response\n  }\n}];"
      },
