      "parameters": {
        "jsCode": "const raw = $json || {};\n\nconst normalizeLabels = (value) => {\n  if (Array.isArray(value)) {\n    return [...new Set(value\n      .map((v) => typeof v === 'string' ? v.trim() : '')\n      .filter(Boolean))];\n  }\n\n  if (typeof value === 'string') {\n    return [...new Set(value\n      .split(',')\n      .map((v) => v.trim())\n      .filter(Boolean))];\n  }\n\n  return [];\n};\n\nconst messageId = typeof raw.messageId === 'string' ? raw.messageId.trim() : '';\nconst labelsToAdd = normalizeLabels(raw.labelsToAdd);\nconst labelsToRemove = normalizeLabels(raw.labelsToRemove);\n\nlet error = '';\nif (!messageId) {\n  error = 'Input field messageId is required and must be a non-empty string.';\n} else if (labelsToAdd.length === 0 && labelsToRemove.length === 0) {\n  error = 'At least one label change is required (labelsToAdd or labelsToRemove).';\n}\n\nreturn [{\n  json: {\n    messageId,\n    labelsToAdd,\n    labelsToRemove,\n    labelsToAddValue: labelsToAdd.join(','),\n    labelsToRemoveValue: labelsToRemove.join(','),\n    doAdd: labelsToAdd.length > 0,\n    doRemove: labelsToRemove.length > 0,\n    okToSetLabels: !error,\n    error\n  }\n}];"
      },
