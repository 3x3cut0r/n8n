        "jsCode": "const input = $('Normalize and validate input').item.json || {};\n\nreturn [{\n  json: {\n    ok: true,\n    action: 'setLabels',\n    messageId: input.messageId || null,\n    labelsToAdd: input.labelsToAdd || [],\n    labelsToRemove: input.labelsToRemove || [],\n    response: {\n      skippedRemove: true\n    }\n  }\n}];"
