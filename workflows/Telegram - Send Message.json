    },
    {
      "parameters": {
        "jsCode": "const resolved = $('Resolve and validate payload').item.json || {};\nconst response = $json;\nconst messageId = response.result && response.result.message_id ? response.result.message_id : null;\nconst hasError = !!response.error || !!response.error_code;\nconst ok = !hasError && messageId !== null;\n\nreturn [{\n  json: {\n    ok,\n    messageId,\n    usedRecipient: resolved.usedRecipient,\n    response\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        192
      ],
      "id": "f7a8b9c0-d1e2-4f3a-4b5c-6d7e8f9a0b1c",
      "name": "Build send result"
    },
