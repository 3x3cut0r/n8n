    {
      "parameters": {
        "content": "# Konfiguration\n\nTrage im Set-Node \"Set default recipient\" die Telegram chat_id ein\n(z. B. 123456789 oder @meinkanal).\nAlternativ kann der Empfaenger per Input-Feld \"recipient\" uebergeben werden.\n\nOptionale Felder (per Input oder leer lassen):\n- parseMode: HTML (Standard), MarkdownV2, Markdown (Legacy)\n- disableNotification: true/false\n- disableWebPagePreview: true/false\n\nCredentials: Telegram Bot-Token muss in n8n als Telegram Credential hinterlegt sein.",
        "height": 304,
        "width": 576
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -208,
        -16
      ],
      "id": "a2b3c4d5-e6f7-4a8b-9c0d-1e2f3a4b5c6d",
      "name": "Config note"
    },
    {
      "parameters": {
        "jsCode": "const normalized = $('Normalize input').item.json || {};\nconst recipientConfig = $('Set default recipient').item.json || {};\n\nconst message = typeof normalized.message === 'string' ? normalized.message.trim() : '';\nconst inputRecipient = typeof normalized.recipient === 'string' ? normalized.recipient.trim() : '';\nconst configuredDefaultRecipient = typeof recipientConfig.defaultRecipient === 'string' ? recipientConfig.defaultRecipient.trim() : '';\n\nconst usedRecipient = inputRecipient || configuredDefaultRecipient;\nconst parseMode = typeof normalized.parseMode === 'string' && normalized.parseMode.trim() !== '' ? normalized.parseMode.trim() : 'HTML';\nconst disableNotification = normalized.disableNotification === true;\nconst disableWebPagePreview = normalized.disableWebPagePreview === true;\n\nlet error = '';\nif (!message) {\n  error = 'Input field message is required and must be a non-empty string.';\n} else if (!usedRecipient) {\n  error = 'No recipient configured. Pass recipient or set value in node Set default recipient.';\n}\n\nreturn [{\n  json: {\n    message,\n    usedRecipient,\n    parseMode,\n    disableNotification,\n    disableWebPagePreview,\n    okToSend: !error,\n    error\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        320
      ],
      "id": "b3c4d5e6-f7a8-4b9c-0d1e-2f3a4b5c6d7e",
